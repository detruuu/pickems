<%- include('partials/header') %>
<section class="card small">
  <h1>Logowanie</h1>
  <p class="muted">Dostęp mają tylko trzy konta wpisane przez administratora w pliku <code>src/config_allowed_users.js</code>.</p>
  <form method="post" action="/login" class="form">
    <label>Login <input name="login" required autocomplete="username"></label>
    <label>Hasło <input name="password" type="password" required autocomplete="current-password"></label>
    <label style="display: flex; align-items: center; gap: 8px; font-weight: normal; cursor: pointer;">
      <input type="checkbox" name="remember" value="yes" style="width: auto; margin: 0;"> Zapamiętaj mnie na 180 dni
    </label>
    <button type="submit">Zaloguj</button>
  </form>
</section>
<%- include('partials/footer') %>
