<%- include('partials/header') %>
<% const readonly = typeof viewingUser !== 'undefined' && viewingUser !== null; %>
<h1>Tabele grup<%= readonly ? ' (podgląd użytkownika ' + viewingUser.name + ')' : '' %></h1>
<p class='muted'>Poniżej znajdują się tabele grup wyliczone na podstawie **<%= readonly ? 'typów użytkownika ' + viewingUser.name : 'Twoich typów' %>** oraz rzeczywiste tabele grup na turnieju. Wiersze są pokolorowane w celach weryfikacji <%= readonly ? 'tych typów' : 'Twoich typów' %> w stosunku do stanu turnieju.</p>
<section class='card' style='margin-bottom: 24px; background: #f8fafc; border: 1px solid #cbd5e1;'>
  <h3 style='margin-top: 0;'>Legenda kolorowania wierszy:</h3>
  <div style='display: flex; flex-wrap: wrap; gap: 16px; font-size: 13px;'>
    <div style='display: flex; align-items: center; gap: 8px;'>
      <span style='display: inline-block; width: 16px; height: 16px; background-color: rgba(34, 197, 94, 0.22); border: 1px solid #166534; border-radius: 4px;'></span>
      <span><strong>Zielony:</strong> Dokładnie trafione miejsce w grupie</span>
    </div>
    <div style='display: flex; align-items: center; gap: 8px;'>
      <span style='display: inline-block; width: 16px; height: 16px; background-color: rgba(234, 179, 8, 0.22); border: 1px solid #854d0e; border-radius: 4px;'></span>
      <span><strong>Żółty:</strong> Inne miejsce, ale zgodność co do awansu/braku awansu</span>
    </div>
    <div style='display: flex; align-items: center; gap: 8px;'>
      <span style='display: inline-block; width: 16px; height: 16px; background-color: rgba(239, 68, 68, 0.22); border: 1px solid #991b1b; border-radius: 4px;'></span>
      <span><strong>Czerwony:</strong> Pomyłka (błędnie wytypowany awans lub brak awansu)</span>
    </div>
  </div>
</section>
<div class='tables-grid'>
  <% Object.keys(predictedTables).forEach((groupName) => { %>
    <div class='mini-table' style='border: 1px solid #cbd5e1; border-radius: 12px; overflow: hidden; background: #fff; box-shadow: 0 4px 6px rgba(0,0,0,0.02);'>
      <h3 style='margin: 0; padding: 12px; background: #f1f5f9; border-bottom: 1px solid #cbd5e1; text-align: center; font-size: 15px;'>
        Grupa <%= groupName %>
      </h3>
      <table style='font-size: 13px; width: 100%; border-collapse: collapse;'>
        <thead>
          <tr style='background: #f8fafc; border-bottom: 1px solid #cbd5e1;'>
            <th style='padding: 8px; text-align: center; width: 30px;'>#</th>
            <th style='padding: 8px; text-align: left;'>Drużyna</th>
            <th style='padding: 8px; text-align: center; width: 40px;'>PKT</th>
            <th style='padding: 8px; text-align: center; width: 50px;'>BRAMKI</th>
          </tr>
        </thead>
        <tbody>
          <% predictedTables[groupName].forEach((team) => { %>
            <% const actualGroup = actualTables[groupName] || []; const actualTeam = actualGroup.find(t => t.id === team.id); let rowStyle = ''; if (actualTeam && actualTeam.played > 0) { if (team.rank === actualTeam.rank) { rowStyle = 'background-color: rgba(34, 197, 94, 0.16); color: #14532d; font-weight: 600;'; } else { const predictedQualified = team.rank <= 2; const actualQualified = actualTeam.rank <= 2; if (predictedQualified === actualQualified) { rowStyle = 'background-color: rgba(234, 179, 8, 0.16); color: #713f12; font-weight: 600;'; } else { rowStyle = 'background-color: rgba(239, 68, 68, 0.16); color: #7f1d1d; font-weight: 600;'; } } } %>
            <tr style='<%= rowStyle %> border-bottom: 1px solid #f1f5f9;'>
              <td style='padding: 8px 6px; text-align: center;'><%= team.rank %></td>
              <td style='padding: 8px 6px; display: flex; align-items: center; gap: 6px;'>
                <% if (team.flag) { %>
                  <img src='https://flagcdn.com/w20/<%= team.flag %>.png' style='width: 20px; height: auto; border: 1px solid #cbd5e1; border-radius: 2px;'>
                <% } %>
                <%= team.name %>
              </td>
              <td style='padding: 8px 6px; text-align: center;'><%= team.points %></td>
              <td style='padding: 8px 6px; text-align: center;'><%= team.gf %>:<%= team.ga %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% }) %>
</div>
<%- include('partials/footer') %>
