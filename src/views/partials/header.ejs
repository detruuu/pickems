<!doctype html>
<html lang="pl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pickems 2026</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<header class="topbar">
  <a class="brand" href="/">Pickems 2026</a>
  <nav>
    <% if (currentUser) { %>
      <a href="/">Typy</a>
      <a href="/ranking">Ranking</a>
          <a href="/bracket">Drabinka</a>
      <% if (currentUser.role === 'admin') { %><a href="/admin">Admin</a><% } %>
      <form action="/logout" method="post" class="inline"><button>Wyloguj</button></form>
    <% } else { %>
      <a href="/login">Logowanie</a>
    <% } %>
  </nav>
</header>
<main class="container">
<% if (flash) { %><div class="flash"><%= flash %></div><% } %>
